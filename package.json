{
  "name": "leaks-manager",
  "version": "1.0.0",
  "private": true,
  "description": "Music/leak management application with SvelteKit frontend and FastAPI microservice",
  "packageManager": "pnpm@9.14.4",
  "scripts": {
    "dev": "pnpm --filter ./svelte dev",
    "build": "pnpm --filter ./svelte build",
    "check": "pnpm --filter ./svelte check",
    "test": "pnpm --filter ./svelte test:run && vitest run && go test ./backend/...",
    "test:frontend": "pnpm --filter ./svelte test:run",
    "test:backend": "go test ./backend/...",
    "test:main": "vitest run",
    "electron:dev": "electron-vite dev",
    "electron:build": "electron-vite build",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3",
    "wails:dev": "wails dev",
    "wails:build": "wails build",
    "wails:build:darwin": "wails build -platform darwin/universal",
    "wails:build:windows": "wails build -platform windows/amd64",
    "wails:doctor": "wails doctor"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.2",
    "electron": "^42.4.0",
    "electron-vite": "^5.0.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "mediabunny": "^1.46.0"
  }
}
