{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2023"],
		"types": ["node"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"noEmit": true,
		"isolatedModules": true,
		"verbatimModuleSyntax": false
	},
	"include": ["electron/**/*.ts", "electron.vite.config.ts", "vitest.config.ts"]
}
