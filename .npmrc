# node-linker=hoisted gives a flat node_modules (no .pnpm symlink store), which is
# what electron-forge's packager requires for pnpm projects (it refuses the default
# symlinked layout). With a flat tree, Forge's deref+ignore packs better-sqlite3 and
# its transitive `bindings` dep correctly into the asar.
node-linker=hoisted
strict-peer-dependencies=false
auto-install-peers=true
